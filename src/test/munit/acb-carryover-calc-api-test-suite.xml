    <!-- =============================================== -->
    <!-- CONSOLE ENDPOINT TESTS -->
    <!-- =============================================== -->

    <munit:test name="test-api-console-access" doc:name="Test API console access" description="Test that API console endpoint is accessible">
        <munit:execution>
            <http:request method="GET" doc:name="GET /console" config-ref="HTTP_Request_configuration" path="/console/">
            </http:request>
        </munit:execution>
        <munit:validation>
            <munit-tools:assert-equals doc:name="Assert status code 200" actual="#[attributes.statusCode]" expected="#[200]"/>
        </munit:validation>
    </munit:test>

    <!-- =============================================== -->
    <!-- BOUNDARY CONDITION TESTS -->
    <!-- =============================================== -->

    <munit:test name="get-carryover-boundary-year-test" doc:name="Test GET /carryover boundary year values" description="Test carryover request with boundary year values">
