        </munit:execution>
        <munit:validation>
            <munit-tools:assert-equals doc:name="Assert status code 400" actual="#[vars.statusCode]" expected="#[400]"/>
        </munit:validation>
    </munit:test>

    <munit:test name="get-carryover-invalid-year-parameter-test" doc:name="Test GET /carryover invalid year parameter" description="Test carryover request with invalid year parameter type">
        <munit:execution>
            <try doc:name="Try">
                <http:request method="GET" doc:name="GET /carryover with invalid year" config-ref="HTTP_Request_configuration" path="/api/carryover">
