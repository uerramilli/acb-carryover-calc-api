                    }]]]></http:query-params>
                </http:request>
                <error-handler>
                    <on-error-continue enableNotifications="true" logException="true" doc:name="On Error Continue" type="HTTP:BAD_REQUEST">
                        <set-variable value="#[error.errorMessage.payload]" doc:name="Set error payload" variableName="errorPayload"/>
                        <set-variable value="#[400]" doc:name="Set status code" variableName="statusCode"/>
                    </on-error-continue>
                </error-handler>
            </try>
        </munit:execution>
        <munit:validation>
            <munit-tools:assert-equals doc:name="Assert status code 400" actual="#[vars.statusCode]" expected="#[400]"/>
        </munit:validation>
    </munit:test>

    <!-- =============================================== -->
    <!-- ERROR HANDLER TESTS -->
    <!-- =============================================== -->

    <munit:test name="test-apikit-bad-request-error-handler" doc:name="Test APIKIT BAD_REQUEST error handler" description="Test the APIKit bad request error handler response">
        <munit:execution>
            <try doc:name="Try">
                <raise-error doc:name="Raise APIKIT:BAD_REQUEST" type="APIKIT:BAD_REQUEST" description="Test bad request error"/>
                <error-handler>
                    <on-error-continue enableNotifications="true" logException="true" doc:name="On Error Continue" type="APIKIT:BAD_REQUEST">
                        <ee:transform doc:name="Transform Message">
                            <ee:message>
                                <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{message: "Bad request"}]]></ee:set-payload>
                            </ee:message>
                            <ee:variables>
                                <ee:set-variable variableName="httpStatus">400</ee:set-variable>
                            </ee:variables>
                        </ee:transform>
                    </on-error-continue>
                </error-handler>
            </try>
        </munit:execution>
        <munit:validation>
            <munit-tools:assert-equals doc:name="Assert httpStatus variable" actual="#[vars.httpStatus]" expected="#[400]"/>
            <munit-tools:assert-that doc:name="Assert payload message" expression="#[payload.message]" is="#[MunitTools::equalTo('Bad request')]"/>
        </munit:validation>
    </munit:test>

    <munit:test name="test-apikit-not-found-error-handler" doc:name="Test APIKIT NOT_FOUND error handler" description="Test the APIKit not found error handler response">
        <munit:execution>
            <try doc:name="Try">
                <raise-error doc:name="Raise APIKIT:NOT_FOUND" type="APIKIT:NOT_FOUND" description="Test not found error"/>
                <error-handler>
                    <on-error-continue enableNotifications="true" logException="true" doc:name="On Error Continue" type="APIKIT:NOT_FOUND">
                        <ee:transform doc:name="Transform Message">
                            <ee:message>
                                <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{message: "Resource not found"}]]></ee:set-payload>
                            </ee:message>
                            <ee:variables>
                                <ee:set-variable variableName="httpStatus">404</ee:set-variable>
                            </ee:variables>
                        </ee:transform>
                    </on-error-continue>
                </error-handler>
            </try>
        </munit:execution>
        <munit:validation>
            <munit-tools:assert-equals doc:name="Assert httpStatus variable" actual="#[vars.httpStatus]" expected="#[404]"/>
            <munit-tools:assert-that doc:name="Assert payload message" expression="#[payload.message]" is="#[MunitTools::equalTo('Resource not found')]"/>
        </munit:validation>
    </munit:test>

    <munit:test name="test-apikit-method-not-allowed-error-handler" doc:name="Test APIKIT METHOD_NOT_ALLOWED error handler" description="Test the APIKit method not allowed error handler response">
        <munit:execution>
